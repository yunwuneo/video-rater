# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=videorater
PGUSER=videorater
PGPASSWORD=your-password

# 身份认证（公网部署时建议开启）
# 设为 true/1/yes 后，访问前需登录；首次启动时若数据库无用户，会用下面账号创建管理员
VIDEO_RATER_AUTH_ENABLED=false
VIDEO_RATER_ADMIN_USER=admin
VIDEO_RATER_ADMIN_PASSWORD=

# 云端 LLM（用于从帧描述、总结文本中提取标签化特征短语）
# 配置后可启用云端提取；不配置则使用本地规则提取
# OpenAI: https://api.openai.com/v1  |  OpenRouter: https://openrouter.ai/api/v1
LLM_APP_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL_NAME=gpt-4o-mini

# Mem0（sync_rated_to_mem0.py 同步已评分视频到 Mem0）
# API Key: https://app.mem0.ai/
MEM0_API_KEY=
MEM0_USER_ID=video_rater
# MEM0_ORG_ID=
# MEM0_PROJECT_ID=
